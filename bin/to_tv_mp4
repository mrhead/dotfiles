#!/bin/sh

# Check if an input file is provided
if [ -z "$1" ]; then
    echo "Usage: to_mp4 <input_video>"
    exit 1
fi

input="$1"
output="${input%.*}_converted.mp4"

# Convert to MP4 using widely compatible codecs (H.264 video, AAC audio)
ffmpeg -i "$input" \
  -c:v libx264 -crf 24 -preset medium \
  -c:a aac -b:a 384k \
  -movflags +faststart \
  -threads 0 \
  "$output"

# Notify the user
echo "✅ Conversion complete: $output"
